<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="bottom"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/expressionDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textColor="#888888"
            android:gravity="end"
            android:fontFamily="sans-serif-light"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="64sp"
            android:textColor="#FFFFFF"
            android:gravity="end"
            android:fontFamily="sans-serif-light"
            android:maxLines="1"
            android:ellipsize="start"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1F1F1F"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:rowCount="5"
        android:columnCount="4"
        android:padding="12dp">

        <Button
            android:id="@+id/btn7"
            android:layout_width="69dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="5dp"
            android:background="@drawable/btn_digit"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="7"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />

        <Button
            android:id="@+id/btn8"
            android:layout_width="71dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="5dp"
            android:background="@drawable/btn_digit"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="8"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />

        <Button
            android:id="@+id/btn9"
            android:layout_width="75dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="5dp"
            android:background="@drawable/btn_digit"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="9"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />

        <Button
            android:id="@+id/btnDivide"
            android:layout_width="87dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="5dp"
            android:background="@drawable/btn_operator"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="/"
            android:textColor="#FF9500"
            android:textSize="26sp" />

        <Button android:id="@+id/btn4" android:text="4"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="22sp" android:textColor="#FFFFFF"
            android:background="@drawable/btn_digit"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btn5" android:text="5"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="22sp" android:textColor="#FFFFFF"
            android:background="@drawable/btn_digit"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btn6" android:text="6"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="22sp" android:textColor="#FFFFFF"
            android:background="@drawable/btn_digit"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btnMultiply" android:text="*"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="26sp" android:textColor="#FF9500"
            android:background="@drawable/btn_operator"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btn1" android:text="1"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="22sp" android:textColor="#FFFFFF"
            android:background="@drawable/btn_digit"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btn2" android:text="2"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="22sp" android:textColor="#FFFFFF"
            android:background="@drawable/btn_digit"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btn3" android:text="3"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="22sp" android:textColor="#FFFFFF"
            android:background="@drawable/btn_digit"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btnMinus" android:text="-"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="26sp" android:textColor="#FF9500"
            android:background="@drawable/btn_operator"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btn0" android:text="0"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="22sp" android:textColor="#FFFFFF"
            android:background="@drawable/btn_digit"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btnClear" android:text="C"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="22sp" android:textColor="#FF453A"
            android:background="@drawable/btn_clear"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btnEquals" android:text="="
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="28sp" android:textColor="#FFFFFF"
            android:background="@drawable/btn_equals"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btnPlus" android:text="+"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="26sp" android:textColor="#FF9500"
            android:background="@drawable/btn_operator"
            android:stateListAnimator="@null" android:elevation="0dp"/>

        <Button android:id="@+id/btnPower" android:text="num"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="4" android:layout_rowWeight="1"
            android:layout_gravity="fill" android:layout_margin="5dp"
            android:textSize="18sp" android:textColor="#888888"
            android:background="@drawable/btn_num"
            android:stateListAnimator="@null" android:elevation="0dp"/>

    </GridLayout>

</LinearLayout>
